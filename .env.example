# Application
APP_NAME="TimeStudy API"
APP_ENV=development
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database (SQLite — change path as needed)
DATABASE_URL=sqlite:///./timestudy.db

# Security — MUST be changed in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth2
OAUTH_CODE_EXPIRE_SECONDS=600

# Initial admin seeded by scripts/seed.py
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme123
